{
  "name": "@target/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npm start",
    "start": "npx nx run-many --target=serve --all --outputStyle=stream",
    "start:shell": "nx run shell:serve --outputStyle=stream",
    "start:bff": "nx run bff:serve --outputStyle=stream",
    "test": "nx run-many -t test --coverage",
    "format:check": "nx format:check",
    "format:write": "nx format:write",
    "lint": "nx run-many -t lint",
    "build": "nx run-many -t build --all",
    "docker:build:shell": "docker build -f frontend/apps/shell/Dockerfile -t target-shell:local .",
    "docker:build:bff": "docker build -f backend/apps/bff/Dockerfile -t target-bff:local .",
    "docker:run:bff": "docker run --rm -d --name bff --network target-net target-bff:local",
    "docker:run:shell": "docker run --rm -d --name shell --network target-net -p 8080:80 -e BFF_HOST=bff -e BFF_PORT=3000 target-shell:local",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "cluster:create": "kind create cluster --name allianz --config kind-config.yaml",
    "cluster:delete": "kind delete cluster --name allianz",
    "kind:load": "kind load docker-image target-bff:local target-shell:local --name allianz",
    "helm:install": "npm run kind:load && helm upgrade --install allianz ./helm/allianz",
    "helm:uninstall": "helm uninstall allianz"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.5",
    "@angular/cdk": "21.2.3",
    "@angular/common": "21.2.5",
    "@angular/compiler": "21.2.5",
    "@angular/core": "21.2.5",
    "@angular/forms": "21.2.5",
    "@angular/platform-browser": "21.2.5",
    "@angular/platform-browser-dynamic": "21.2.5",
    "@angular/router": "21.2.5",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/platform-express": "^11.1.17",
    "axios": "^1.13.6",
    "es-module-shims": "^2.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.2",
    "zone.js": "0.16.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.3",
    "@angular-devkit/core": "21.2.3",
    "@angular-devkit/schematics": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.5",
    "@angular/language-service": "21.2.5",
    "@aposin/ng-aquila": "^20.0.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@ngrx/signals": "^21.0.1",
    "@nx/angular": "22.6.1",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/jest": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/nest": "22.6.1",
    "@nx/node": "22.6.1",
    "@nx/web": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@schematics/angular": "21.2.3",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.21",
    "@swc/helpers": "0.5.19",
    "@types/jest": "30.0.0",
    "@types/node": "25.5.0",
    "@typescript-eslint/utils": "^8.57.1",
    "angular-eslint": "21.3.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-jest-formatting": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-environment-node": "30.3.0",
    "jest-preset-angular": "16.1.1",
    "jest-util": "30.3.0",
    "nx": "22.6.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "10.9.2",
    "tslib": "^2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.57.1",
    "webpack-cli": "^7.0.2"
  }
}
